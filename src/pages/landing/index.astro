---
/**
 * Landing page — served at landing.yourdomain.com via Netlify rewrite.
 */
import '../../styles/landing.css';
const title = 'Syncera Inc — Get More Clients in 30 Days';
const lang = 'en';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>

<!-- LOGO -->
<div class="site-logo"><span>S</span><span class="slit">Y</span><span class="slit">N</span><span>C</span><span>E</span><span>R</span><span class="slit">A</span></div>
<p class="site-tagline">STRATEGY &middot; BRANDING &middot; GROWTH</p>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <h1 class="fade-up">We Build Brands That Don't Compete — <span class="highlight">They Dominate.</span></h1>
    <p class="subheadline fade-up stagger-1">We  help real estate professionals, personal brands, and e-commerce companies turn their presence into a high-converting growth system</p>
  </div>
</section>
 
<!-- AUDIENCE PANELS -->
<section class="audience-section">
  <div class="audience-panels">
    <div class="audience-panel fade-up" style="background-image:url('https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=800&q=80')">
      <div class="audience-overlay"></div>
      <div class="audience-content">
        <h2 class="audience-topline">REAL ESTATE<br/>PROFESSIONALS</h2>
        <p class="audience-text">Become the agent everyone knows and trusts.</p>
        <p class="audience-text">Attract clients instead of chasing them.</p>
        <a href="https://syncerainc.com/#contact" class="audience-btn">I'm a Real Estate Agent <span class="arrow">&rarr;</span></a>
      </div>
    </div>
    <div class="audience-panel fade-up stagger-1" style="background-image:url('https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=800&q=80')">
      <div class="audience-overlay"></div>
      <div class="audience-content">
        <h2 class="audience-topline">COACHES &amp;<br/>PERSONAL BRANDS</h2>
        <p class="audience-text">Turn your expertise into a premium brand that sells.</p>
        <p class="audience-text">Position yourself to attract high-ticket clients.</p>
        <a href="https://syncerainc.com/#contact" class="audience-btn">I'm a Coach / Personal Brand <span class="arrow">&rarr;</span></a>
      </div>
    </div>
    <div class="audience-panel fade-up stagger-2" style="background-image:url('https://images.unsplash.com/photo-1556228720-195a672e8a03?w=800&q=80')">
      <div class="audience-overlay"></div>
      <div class="audience-content">
        <h2 class="audience-topline">E-COMMERCE<br/>BRANDS</h2>
        <p class="audience-text">Turn your brand into a high-converting machine.</p>
        <p class="audience-text">Scale profitably, not just traffic.</p>
        <a href="https://syncerainc.com/#contact" class="audience-btn">I run an E-commerce Brand <span class="arrow">&rarr;</span></a>
      </div>
    </div>
  </div>
</section>

<!-- SOLUTION / BENEFITS STRIP -->
<section class="solution-section">
  <div class="solution-strip">
    <div class="solution-item fade-up">
      <div class="sol-icon-wrap">
        <svg class="sol-icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="24" cy="24" r="18"/>
          <circle cx="24" cy="24" r="10"/>
          <circle cx="24" cy="24" r="3" fill="currentColor" stroke="none"/>
        </svg>
      </div>
      <div class="sol-text">
        <h3>STRATEGIC<br/>POSITIONING</h3>
        <p>Stand out in your market<br/>and own your space.</p>
      </div>
    </div>
    <div class="solution-item fade-up stagger-1">
      <div class="sol-icon-wrap">
        <svg class="sol-icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="12" y="6" width="24" height="36" rx="2"/>
          <line x1="18" y1="16" x2="30" y2="16"/>
          <line x1="18" y1="22" x2="30" y2="22"/>
          <line x1="18" y1="28" x2="26" y2="28"/>
        </svg>
      </div>
      <div class="sol-text">
        <h3>CONTENT THAT<br/>BUILDS AUTHORITY</h3>
        <p>Content systems that<br/>attract, engage &amp; convert.</p>
      </div>
    </div>
    <div class="solution-item fade-up stagger-2">
      <div class="sol-icon-wrap">
        <svg class="sol-icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="6,10 42,10 28,26 28,40 20,36 20,26"/>
        </svg>
      </div>
      <div class="sol-text">
        <h3>GROWTH SYSTEMS<br/>THAT DELIVER</h3>
        <p>Proven systems that generate<br/>inbound leads and sales.</p>
      </div>
    </div>
    <div class="solution-item fade-up stagger-3">
      <div class="sol-icon-wrap">
        <svg class="sol-icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="6" y1="42" x2="42" y2="42"/>
          <rect x="10" y="28" width="6" height="14"/>
          <rect x="21" y="20" width="6" height="22"/>
          <rect x="32" y="12" width="6" height="30"/>
        </svg>
      </div>
      <div class="sol-text">
        <h3>MEASURABLE<br/>RESULTS</h3>
        <p>Real growth, real clients,<br/>real revenue.</p>
      </div>
    </div>
  </div>
</section>

<!-- BOTTOM CTA -->
<section class="bottom-cta-section">
  <div>
      <h3/>Your growth doesn't come from doing more - it comes from doing it right.</h3>
    <a href="https://syncerainc.com/#contact" class="cta-btn fade-up stagger-2">Book Your Strategy Call <span class="arrow">&rarr;</span></a>
    <a href="https://syncerainc.com/#contact" class="cta-btn fade-up stagger-2">Get a Free audit <span class="arrow">&rarr;</span></a>
  </div>
</section>
<script>
  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15 });
 
  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
</script>
 
  </body>
</html>
